<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Care Companion Setup" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Enter your WINCO server details" android:textSize="14sp"
        android:textColor="#888888" android:layout_marginBottom="32dp"/>
    <EditText android:id="@+id/et_emr_url" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="WINCO Server URL (e.g. http://192.168.1.5:5000/)" android:inputType="textUri" android:layout_marginBottom="16dp"/>
    <EditText android:id="@+id/et_username" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Username" android:inputType="text" android:layout_marginBottom="16dp"/>
    <EditText android:id="@+id/et_password" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Password" android:inputType="textPassword" android:layout_marginBottom="32dp"/>
    <Button android:id="@+id/btn_complete_setup" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Connect"/>
</LinearLayout>